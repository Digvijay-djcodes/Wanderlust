<style>
  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }
  .search-btn i {
    display: inline;
    margin-right: 0.5rem;
  }
  .search-btn:hover {
    background-color: white;
    color: #fe424d;
    border: 1px solid #fe424d;
  }
  .search-btn:focus {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
    box-shadow: 0 0 0 0.25rem rgba(254, 66, 77, 0.5);
  }
  .search-input {
    border-radius: 25px;
    border: 1px solid #ced4da;
    padding: 0.5rem 3rem 0.5rem 3rem;
    transition: border-color 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
  }

</style>
