<% layout('layouts/boilerplate') %> 
<script> 
    const mapToken = "<%= mapToken %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<div class="row mt-3">
    <div class="col-8 offset-3">    
        <h3><%= listing.title %></h3>
        <br>
    </div>
        <div class="card col-6 offset-3 listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <br>
                    <strong>Owner:</strong> <%= listing.owner ? listing.owner.username : "Deleted User" %> <br>
                    <strong>Category:</strong> <%= listing.category %> <br>
                    <strong>Description:</strong> <%= listing.description %> <br>
                    <strong>Location:</strong> <%= listing.location %> <br>
                    <strong>Country:</strong> <%= listing.country %> <br>
    <div class="price-row">

        <div class="price">
            ₹ 
            <span id="basePrice">
            <%= listing.price.toLocaleString("en-IN") %>
            </span>

            <span id="taxPrice" style="display: none;">
               <%= Math.round(listing.price * 1.18).toLocaleString("en-IN") %>
            </span>

            <span class="per-night"> / night</span>
        </div>

        <div class="tax-toggle">
    
            <label class="switch">
            <input type="checkbox" id="taxToggle">
            <span class="slider"></span>
            </label>

            <span class="toggle-text">Display Total After Taxes</span>

        </div>

</div>
                    
                </p>
            </div>
        </div>
        <!--<a href="/listings/<%= listing._id %>/edit">Edit Listing</a> -->
        <br>
        <% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>
        <div class="btns">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">
                Edit
                </a>

                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                    <button class="btn btn-dark delete-btn offset-5">Delete</button>
                </form>
        </div>
        <% } %>

        <div class="col-8 offset-3 mb-3">
            <hr>
            <% if(currentUser){ %>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3" >
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot" id="rating" name="review[rating]">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible"></label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good"></label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average"></label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good"></label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing"></label>
                    </fieldset>
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea id="comment" name="review[comment]" rows="5" cols="30" class="form-control" required></textarea>
                    <div class="invalid-feedback">
                        Please enter a valid comment.
                    </div>
                </div>
                <br>
                <button type="submit" class="btn btn-outline-dark">Submit Review</button>

            </form>
            <% } else { %>
                <br>
                <h4><a href="/login" >Login</a> to leave a review.</h4>
            <% } %>
            <br>
            <hr>
            

            <h4>All Reviews</h4>
            <br>
            <div class="row">
                <% if(listing.reviews.length === 0){ %>
                    <p>No reviews yet. Be the first to review!</p>
                <% } %>
                <% for(review of listing.reviews){ %>
                <div class="card col-5 mb-3 ms-3">
                    <div class="card-body">
                    
                        <h5 class="card-title">@<%= review.author ? review.author.username : "Deleted User" %></h5>
                        <h6 class="card-subtitle mb-2 text-body-secondary"><%= review.rating %> stars</h6>
                        <p class="starability-result card-subtitle mb-2 text-body-secondary" data-rating=<%= review.rating %>>::</p>
                        <p class="card-text"><%= review.comment %></p>
                    </div>
                    <% if(currentUser && currentUser._id.equals(review.author._id)){ %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger btn-sm mb-3 mt-3">Delete Review</button>
                    </form>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>
            <hr class="col-8 offset-3 mb-3">
            <div class="col-6 offset-3 mb-3">
                <h3>Where you'll be</h3>
                <br>
                <div id="my-map" style="height: 400px; width: 100%;">

                </div>
            </div>
    </div>

<script src="/js/map.js"></script>
    <br>

<style>
.price-row {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: 10px;
}

.tax-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* SWITCH */
.switch {
  position: relative;
  display: inline-block;
  width: 42px;
  height: 22px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  background-color: #ccc;
  border-radius: 34px;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  transition: 0.3s;
}

.slider:before {
  position: absolute;
  content: "";
  height: 16px;
  width: 16px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  border-radius: 50%;
  transition: 0.3s;
}

input:checked + .slider {
  background-color: #fe424d;
}

input:checked + .slider:before {
  transform: translateX(20px);
}

.toggle-text {
  font-size: 0.9rem;
  color: #555;
}
</style>

<script>
const toggle = document.getElementById("taxToggle");
const basePrice = document.getElementById("basePrice");
const taxPrice = document.getElementById("taxPrice");

if (toggle) {
    toggle.addEventListener("change", () => {
        if (toggle.checked) {
            basePrice.style.display = "none";
            taxPrice.style.display = "inline";
        } else {
            basePrice.style.display = "inline";
            taxPrice.style.display = "none";
       }  
});
}
</script>